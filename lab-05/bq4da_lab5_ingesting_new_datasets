# ==============================================================================
# TASK 2 — Ingest a New Dataset from a CSV
# ==============================================================================
# Scenario: your operations team has provided a product inventory CSV with
# stock levels and restocking lead times. This data does not exist in the
# existing ecommerce transactional dataset and needs to be loaded separately.
#
# UI steps (BigQuery Console):
#   1. Download the CSV from:
#      https://storage.googleapis.com/spls/gsp411/exports/products.csv
#   2. Click View Actions next to the ecommerce dataset > Create Table
#   3. Source:      Upload | select downloaded file | File format: CSV
#   4. Destination: Table name: products
#   5. Schema:      Check Auto Detect
#   6. Click Create Table
#
# Schema auto-detected from the CSV:
#   SKU                 STRING
#   name                STRING
#   orderedQuantity     INTEGER
#   stockLevel          INTEGER
#   restockingLeadTime  INTEGER
#   sentimentScore      FLOAT
#   sentimentMagnitude  FLOAT
# ==============================================================================

# Task 2 SQL: Explore the newly loaded products table
# After loading, validate the data and get a quick feel for the inventory landscape.
# Ordering by stockLevel descending surfaces the most overstocked products first,
# which is useful context before doing the restocking analysis in Task 4.

QUERY_TOP_STOCK_LEVELS = """
SELECT *
FROM ecommerce.products
ORDER BY stockLevel DESC
LIMIT 5;
-- Returns the 5 products with the highest current stock.
-- Use this as a basic sanity check after loading: confirm column names,
-- data types, and that values look reasonable before running deeper analysis.
"""


# ==============================================================================
# TASK 3 — Ingest Data from Cloud Storage
# ==============================================================================
# Same products.csv file, this time loaded directly from a GCS bucket
# instead of a local upload. This is the preferred approach in production
# since it avoids file size limits on local uploads and is repeatable.
#
# UI steps (BigQuery Console):
#   1. Click View Actions next to ecommerce dataset > Create Table
#   2. Source:      Google Cloud Storage
#                   Bucket path: spls/gsp411/exports/products.csv
#                   File format: CSV
#   3. Destination: Table name: products
#   4. Schema:      Check Auto Detect
#   5. Click Create Table
#
# This will FAIL on the first attempt because the products table already
# exists from Task 2 and the default write preference is "Write if empty."
#
# Fix:
#   1. Click Go To Job when the error appears
#   2. Click Repeat Load Job
#   3. In Advanced Options, change Write Preference to: Overwrite Table
#   4. Click Create Table
#
# Key lesson: always set Write Preference intentionally.
#   Write if empty  = safe default, fails if table exists
#   Append to table = adds rows, can create duplicates if re-run
#   Overwrite table = replaces all data, idempotent and safe for full refreshes
# ==============================================================================


# ==============================================================================
# TASK 4 — Ingest a New Dataset from a Google Spreadsheet
# ==============================================================================
# After saving query results to Sheets (Task 5 below), you link that
# spreadsheet back into BigQuery as an external table. This creates a live
# connection: any edits made in the Sheet are reflected immediately when
# you query the BQ table, with no re-ingestion required.
#
# UI steps (BigQuery Console):
#   1. Click View Actions next to ecommerce dataset > Create Table
#   2. Source:      Drive
#                   Drive URI: (paste your Google Sheet share link here)
#                   File format: Google Sheet
#   3. Destination: Table type: External Table (leave as default)
#                   Table name: products_comments
#   4. Schema:      Check Auto Detect
#   5. Advanced:    Header rows to skip: 1
#   6. Click Create Table
#
# Note: no load job runs for external tables. BigQuery stores only the
# connection metadata, not the data itself. The Sheet remains the source
# of truth and BQ reads it live on every query.
# ==============================================================================

# Task 4 SQL: Restocking priority analysis
# SAFE_DIVIDE() is the BigQuery-safe version of the division operator.
# Regular division (orderedQuantity / stockLevel) raises an error on
# division by zero. SAFE_DIVIDE() returns NULL instead, which is the
# correct behavior for products that have stock but zero orders.
#
# The ratio (orderedQuantity / stockLevel) represents inventory turnover
# pressure: a ratio >= 0.8 means 80% or more of current stock has already
# been ordered, flagging these products as restock candidates.
# Combined with restockingLeadTime, this surfaces the most urgent items first.

QUERY_RESTOCK_PRIORITY = """
SELECT
    *,
    SAFE_DIVIDE(orderedQuantity, stockLevel) AS ratio
FROM ecommerce.products
WHERE orderedQuantity > 0
  AND SAFE_DIVIDE(orderedQuantity, stockLevel) >= 0.8
ORDER BY restockingLeadTime DESC;
-- Products with >= 80% inventory depletion, sorted by longest restock lead time.
-- These are the highest-risk items: high demand, low remaining stock,
-- and the slowest to replenish. First candidates for a supplier contact.
"""


