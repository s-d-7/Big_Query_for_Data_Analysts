# The restock priority query results are saved to Google Sheets so the
# supply chain team can add operational notes (e.g. "new shipment on the way")
# directly in the spreadsheet without needing BigQuery access.
#
# UI steps:
#   1. Run QUERY_RESTOCK_PRIORITY above
#   2. In Query Results, click Save Results > Google Sheets
#   3. Open the generated spreadsheet
#   4. Add a new column G with header: comments
#   5. Add a note in the first data row (e.g. "new shipment on the way")
#   6. Share the sheet and copy the link
#   7. Use that link as the Drive URI in Task 4 to create the external table
# ==============================================================================

# Task 5 SQL: Query the external table to surface non-null comments
# This query is run after creating the products_comments external table.
# Filtering WHERE comments IS NOT NULL returns only rows the supply chain
# team has actively annotated, keeping the output focused and actionable.

QUERY_PRODUCTS_WITH_COMMENTS = """
SELECT *
FROM ecommerce.products_comments
WHERE comments IS NOT NULL;
-- Returns only products that have been annotated by the supply chain team.
-- Because this is an external table, re-running this query after editing
-- the Sheet will reflect the latest comments without any re-ingestion.
"""


# ==============================================================================
# TASK 6 — External Table Performance and Data Quality Considerations
# ==============================================================================
# This task is conceptual rather than SQL-based, but the tradeoffs are
# important to understand before using external tables in production.
#
# External tables (Google Sheets, GCS without loading) vs native BQ tables:
#
# EXTERNAL TABLE BENEFITS:
#   - No ingestion step required: data is always current
#   - Useful for operational data that changes frequently (e.g. annotations,
#     config tables, lookup tables managed by non-technical teams)
#   - Faster to set up for exploratory or one-off analysis
#
# EXTERNAL TABLE LIMITATIONS:
#   - Data consistency is not guaranteed: if the Sheet is edited mid-query,
#     results may reflect a mix of old and new values
#   - No BigQuery storage optimization: auto-partitioning, clustering, and
#     query execution path optimization only apply to native BQ tables
#   - Some BigQuery functions are unavailable on external tables
#     (e.g. certain wildcard functions, DML operations)
#   - Query performance is slower because BQ must read from the external
#     source on every execution rather than from optimized columnar storage
#
# Rule of thumb:
#   Use external tables for operational lookups and lightweight annotation.
#   Load into native BQ tables for anything queried frequently, at scale,
#   or where consistency and performance are business requirements.
# ==============================================================================
